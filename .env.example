# API Keys for financial data sources
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Federal Reserve Economic Data (free: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Alpha Vantage (free tier: https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=

# SEC EDGAR requires a user agent (your email, no key needed)
SEC_EDGAR_USER_AGENT=your.email@example.com
